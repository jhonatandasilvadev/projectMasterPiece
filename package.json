{
  "name": "restaurant-saas-mvp",
  "private": true,
  "scripts": {
    "setup": "npm --prefix backend install && npm --prefix frontend install",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "backend:prisma:generate": "npm --prefix backend run prisma:generate",
    "backend:prisma:migrate": "npm --prefix backend run prisma:migrate",
    "backend:prisma:seed": "npm --prefix backend run prisma:seed",
    "dev": "sh -c 'npm --prefix backend run dev & npm --prefix frontend run dev'"
  }
}
